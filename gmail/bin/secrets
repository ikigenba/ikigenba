#!/usr/bin/env bash
# bin/secrets — seed/rotate gmail's secrets in the shared app-config blob.
#
# Workstation-side control-plane action (no ssh, no box). NON-DESTRUCTIVE
# read-modify-write of ONLY this app's key in /ikigenba/<ACCOUNT>/app-config
# (a single SecureString shared across every app on the box). Every other
# app's key in the blob is preserved untouched.
#
# gmail has exactly three secrets — a DEDICATED desktop OAuth client + the owner
# refresh token (decisions §2, NOT reused GOOGLE_*): GMAIL_CLIENT_ID,
# GMAIL_CLIENT_SECRET, GMAIL_REFRESH_TOKEN (full https://mail.google.com/ scope).
# The binary reads them via getenv at its composition root. They MUST be seeded
# BEFORE first start — ikigenba-launch hard-fails if .["gmail"] is missing from
# app-config.
#
# Values come from ~/.secrets/<NAME> (same source as the local .envrc); any can be
# overridden by an env var of the same name. The values are NEVER read aloud,
# printed, or logged — only masked in the summary below. The GMAIL_REFRESH_TOKEN
# in ~/.secrets is the one the consent CLI self-wrote during the bootstrap sitting.
# Non-secret config (resource id, auth server, db path, poll interval) is NOT
# stored here — the box derives it from IKIGENBA_DOMAIN/PORT.
#
# Requires a live SSO session (`aws sso login --profile int`) — the user runs
# that interactively; this script does not.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env
. etc/deploy.env

PARAM="/ikigenba/${ACCOUNT}/app-config"
AWS_PROFILE_NAME="${AWS_PROFILE:-${ACCOUNT}}"
AWS_REGION_NAME="${AWS_REGION:-us-east-2}"
SECRETS_DIR="${SECRETS_DIR:-$HOME/.secrets}"

aws_() { aws --profile "$AWS_PROFILE_NAME" --region "$AWS_REGION_NAME" "$@"; }

resolve() {
  local name="$1" val
  if [ -n "${!name:-}" ]; then
    val="${!name}"
  elif [ -r "$SECRETS_DIR/$name" ]; then
    val="$(cat "$SECRETS_DIR/$name")"
  else
    echo "!! $name not set and $SECRETS_DIR/$name not readable" >&2
    exit 1
  fi
  printf '%s' "$val" | tr -d '[:space:]'
}

CLIENT_ID="$(resolve GMAIL_CLIENT_ID)"
CLIENT_SECRET="$(resolve GMAIL_CLIENT_SECRET)"
REFRESH_TOKEN="$(resolve GMAIL_REFRESH_TOKEN)"

[ -n "$CLIENT_ID" ]     || { echo "!! GMAIL_CLIENT_ID is empty" >&2; exit 1; }
[ -n "$CLIENT_SECRET" ] || { echo "!! GMAIL_CLIENT_SECRET is empty" >&2; exit 1; }
[ -n "$REFRESH_TOKEN" ] || { echo "!! GMAIL_REFRESH_TOKEN is empty" >&2; exit 1; }

EXISTING="$(aws_ ssm get-parameter --name "$PARAM" --with-decryption \
  --query Parameter.Value --output text 2>/dev/null || true)"
if BASE="$(printf '%s' "$EXISTING" | jq -e . 2>/dev/null)"; then :; else BASE='{}'; fi

NEW="$(printf '%s' "$BASE" | jq \
  --arg n "$APP" --arg id "$CLIENT_ID" --arg secret "$CLIENT_SECRET" --arg refresh "$REFRESH_TOKEN" \
  '.[$n] = {GMAIL_CLIENT_ID:$id, GMAIL_CLIENT_SECRET:$secret, GMAIL_REFRESH_TOKEN:$refresh}')"

mask() { local s="$1"; [ "${#s}" -le 8 ] && { echo '****'; return; }; \
         printf '%s…%s\n' "${s:0:4}" "${s: -4}"; }
SIBLINGS="$(printf '%s' "$BASE" | jq -r --arg n "$APP" \
  'keys - [$n] | join(", ") | if . == "" then "(none)" else . end')"

echo
echo "  SECRETS — write key .${APP} into ${PARAM}"
echo "    profile/region          : ${AWS_PROFILE_NAME} / ${AWS_REGION_NAME}"
echo "    GMAIL_CLIENT_ID         : $(mask "$CLIENT_ID")"
echo "    GMAIL_CLIENT_SECRET     : $(mask "$CLIENT_SECRET")"
echo "    GMAIL_REFRESH_TOKEN     : $(mask "$REFRESH_TOKEN")"
echo "    sibling keys preserved  : $SIBLINGS"
echo
printf '  Type "yes" to write: '
read -r ANS
[ "$ANS" = "yes" ] || { echo ">> aborted (nothing written)."; exit 1; }

TMP="$(mktemp)"; chmod 600 "$TMP"
trap 'rm -f "$TMP"' EXIT
printf '%s' "$NEW" > "$TMP"
aws_ ssm put-parameter --name "$PARAM" \
  --type SecureString --overwrite --value "file://$TMP" >/dev/null

echo ">> .${APP} written to ${PARAM}. Apply with: bin/ship (then opsctl stage/deploy) or systemctl restart ${APP}."
