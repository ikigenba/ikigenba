#!/usr/bin/env bash
# bin/push-secrets — seed or overwrite the one SSM SecureString app-config
# parameter for a suite service.
#
#   bin/push-secrets <app>
#   bin/push-secrets --all
#   bin/push-secrets --dry-run [<app>|--all]
#
# Each deployable service has exactly one parameter:
#
#   /ikigenba/<ACCOUNT>/app-config/<app>
#
# The value is a flat JSON object built from the app's .envrc lines that match
# exactly:
#
#   export NAME="$(cat ~/.secrets/NAME)"
#
# Same-named environment variables override ~/.secrets files. Secret values are
# stripped of whitespace, must be non-empty, are written only to chmod 600 temp
# files, and are never printed or passed on a command line. No matching .envrc
# lines means the app is explicitly seeded with {}.
set -euo pipefail

usage() {
  cat <<'USAGE'
bin/push-secrets — push one SSM SecureString app-config JSON parameter per service.

Usage:
  bin/push-secrets <app>
  bin/push-secrets --all
  bin/push-secrets --dry-run [<app>|--all]

Arguments:
  <app>        service to seed (ledger, crm, dashboard, ...). Must have
               <app>/VERSION and <app>/etc/deploy.env.

Flags:
  --all        discover every deployable top-level app by */VERSION and push each.
  --dry-run    print the parameter name and key names without calling AWS.
  -h, --help   show this help.

Environment:
  AWS_PROFILE  defaults to ACCOUNT from <app>/etc/deploy.env.
  AWS_REGION   defaults to us-east-2.

The app .envrc is parsed by the strict line form:
  export NAME="$(cat ~/.secrets/NAME)"

No matching lines, or no .envrc, pushes {} so secret-less apps are deliberately
seeded.
USAGE
}

DRY_RUN=0
ALL=0
APP=""

for arg in "$@"; do
  case "$arg" in
    -h|--help)  usage; exit 0 ;;
    --dry-run)  DRY_RUN=1 ;;
    --all)      ALL=1 ;;
    -*)
      echo "!! unknown flag: $arg" >&2
      usage >&2
      exit 2
      ;;
    *)
      if [ -z "$APP" ]; then
        APP="$arg"
      else
        echo "!! too many arguments: $arg" >&2
        usage >&2
        exit 2
      fi
      ;;
  esac
done

if [ "$ALL" = "1" ] && [ -n "$APP" ]; then
  echo "!! pass either <app> or --all, not both" >&2
  usage >&2
  exit 2
fi

if [ "$ALL" = "0" ] && [ -z "$APP" ]; then
  echo "!! missing <app> or --all" >&2
  usage >&2
  exit 2
fi

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"

TEMPS=()
cleanup() {
  if [ "${#TEMPS[@]}" -gt 0 ]; then
    rm -f "${TEMPS[@]}"
  fi
}
trap cleanup EXIT

make_temp() {
  local path
  path="$(mktemp "${TMPDIR:-/tmp}/suite-push-secrets.XXXXXX")"
  chmod 600 "$path"
  TEMPS+=("$path")
  printf '%s\n' "$path"
}

discover_apps() {
  local version
  for version in */VERSION; do
    [ -f "$version" ] || continue
    printf '%s\n' "${version%/VERSION}"
  done | sort
}

mask_value() {
  local value="$1"
  local len="${#value}"
  if [ "$len" -le 8 ]; then
    printf '****'
  else
    printf '%s****%s' "${value:0:4}" "${value: -4}"
  fi
}

parse_secret_names() {
  local app="$1"
  local envrc="${app}/.envrc"
  local line name rhs

  [ -f "$envrc" ] || return 0

  while IFS= read -r line || [ -n "$line" ]; do
    if [[ "$line" =~ ^export\ ([A-Z_][A-Z0-9_]*)=\"\$\(cat\ ~/\.secrets/([A-Z_][A-Z0-9_]*)\)\"$ ]]; then
      name="${BASH_REMATCH[1]}"
      rhs="${BASH_REMATCH[2]}"
      if [ "$name" = "$rhs" ]; then
        printf '%s\n' "$name"
      fi
    fi
  done < "$envrc"
}

resolve_secret() {
  local name="$1"
  local value=""
  local file="${HOME}/.secrets/${name}"

  if [ -n "${!name+x}" ]; then
    value="$(printf '%s' "${!name}" | tr -d '[:space:]')"
  elif [ -f "$file" ]; then
    value="$(tr -d '[:space:]' < "$file")"
  else
    echo "!! ${name}: missing environment variable and ${file}" >&2
    return 1
  fi

  if [ -z "$value" ]; then
    echo "!! ${name}: resolved empty value" >&2
    return 1
  fi

  printf '%s' "$value"
}

push_app() {
  local app="$1"
  local deploy_env="${app}/etc/deploy.env"
  local names_text name account param kv_tmp json_tmp value profile region
  local ACCOUNT
  local -a names=()

  [ -d "$app" ] || { echo "!! no such service dir: ${app}/" >&2; return 1; }
  [ -f "${app}/VERSION" ] || { echo "!! missing ${app}/VERSION — ${app} is not deployable" >&2; return 1; }
  [ -f "$deploy_env" ] || { echo "!! missing ${deploy_env}" >&2; return 1; }

  # shellcheck source=/dev/null
  . "$deploy_env"
  account="${ACCOUNT:?ACCOUNT must be set in ${deploy_env}}"
  param="/ikigenba/${account}/app-config/${app}"

  names_text="$(parse_secret_names "$app" | sort -u)"
  if [ -n "$names_text" ]; then
    while IFS= read -r name; do
      [ -n "$name" ] && names+=("$name")
    done <<< "$names_text"
  fi

  if [ "$DRY_RUN" = "1" ]; then
    echo ">> ${app}: ${param}"
    if [ "${#names[@]}" -eq 0 ]; then
      echo "   keys: (none) -> {}"
    else
      echo "   keys: ${names[*]}"
    fi
    echo "   dry-run: not calling aws"
    return 0
  fi

  kv_tmp="$(make_temp)"
  json_tmp="$(make_temp)"

  : > "$kv_tmp"
  for name in "${names[@]}"; do
    value="$(resolve_secret "$name")" || return 1
    printf '%s\t%s\n' "$name" "$value" >> "$kv_tmp"
  done

  if [ "${#names[@]}" -eq 0 ]; then
    printf '{}\n' > "$json_tmp"
  else
    jq -Rn '
      reduce inputs as $line ({};
        ($line | split("\t")) as $pair
        | . + {($pair[0]): $pair[1]}
      )
    ' < "$kv_tmp" > "$json_tmp"
  fi

  echo ">> ${app}: ${param}"
  if [ "${#names[@]}" -eq 0 ]; then
    echo "   keys: (none) -> {}"
  else
    for name in "${names[@]}"; do
      value="$(resolve_secret "$name")" || return 1
      echo "   ${name}=$(mask_value "$value")"
    done
  fi

  profile="${AWS_PROFILE:-$account}"
  region="${AWS_REGION:-us-east-2}"
  AWS_PROFILE="$profile" AWS_REGION="$region" \
    aws ssm put-parameter \
      --name "$param" \
      --type SecureString \
      --overwrite \
      --value "file://${json_tmp}"
}

main() {
  local app rc failures=0
  local -a apps=()

  if [ "$ALL" = "1" ]; then
    while IFS= read -r app; do
      [ -n "$app" ] && apps+=("$app")
    done < <(discover_apps)
  else
    apps=("$APP")
  fi

  for app in "${apps[@]}"; do
    if push_app "$app"; then
      :
    else
      rc=$?
      echo "!! ${app}: failed" >&2
      failures=$((failures + 1))
      [ "$ALL" = "1" ] || return "$rc"
    fi
  done

  if [ "$failures" -gt 0 ]; then
    return 1
  fi
}

main
