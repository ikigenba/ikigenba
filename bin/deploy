#!/usr/bin/env bash
# bin/deploy — the ONE shared deploy wrapper for the whole ikigai suite
# (PLAN §1.5). Replaces the per-service cloned */bin/deploy.
#
#   bin/deploy <app>
#
# It is deliberately thin: it owns the OFF-BOX BUILD HALF only — there is NO
# install logic on the laptop. After building it hands the single static artifact
# to the box's `opsctl install`, which owns the release-dir / atomic-swap /
# migrate / restart / rollback machinery (PLAN §1.3–1.4).
#
# The version is the committed file <app>/VERSION (a bare X.Y.Z) — git tags are NO
# LONGER the version mechanism. deploy always builds CURRENT main (HEAD); whatever
# version is committed in <app>/VERSION on HEAD is what ships. There is no version
# argument: bump the file with bin/bump first, then deploy builds that committed
# state.
#
# What it does:
#   1. Source <app>/etc/deploy.env (ACCOUNT, SSH_USER, SSH_KEY; HOST defaults to
#      ${ACCOUNT}.metaspot.org).
#   2. Build CURRENT main (HEAD) in a throwaway `git worktree` (PLAN §4 dec 4) so
#      the build is reproducible, excludes any uncommitted working-tree edits, and
#      never disturbs the operator's tree. The artifact reflects exactly what is
#      committed on main — the point of the file-on-main version model.
#      Build flags honor §2: CGO_ENABLED=0 GOOS=linux GOARCH=amd64 GOWORK=off
#      -trimpath -buildvcs=false, ldflags stamping appkit.version/appkit.commit.
#      The build runs INSIDE the worktree's <app>/ dir so the committed
#      `replace appkit/eventplane/agentkit => ../...` directives resolve against
#      the worktree's sibling lib trees (no network).
#   3. Read the version FROM THE WORKTREE'S <app>/VERSION (the actual build
#      source), prepend "v" -> the BARE release name handed to opsctl.
#   4. scp the single artifact to the box /tmp, then
#      ssh sudo opsctl install <app> <bare-version> --artifact /tmp/<file>.
#
# --dry-run (or DRY_RUN=1) does the FULL build (producing the artifact) but PRINTS
# the scp/ssh/opsctl commands instead of running them, so the build half is fully
# exercisable off-box while the box half stays gated (PLAN C3 / verified in D2).
#
# Honors §2: the box never compiles; -buildvcs=false is mandatory (the module is a
# subdir of a bare mono-repo .git — Go's auto VCS stamp would abort); GOWORK=off so
# the prod build is deterministic without the dev workspace; the in-repo lib source
# trees come along in the worktree for the replace directives. Never reads or prints
# secrets / the SSH key contents.
set -euo pipefail

usage() {
  cat <<'USAGE'
bin/deploy — build the current main of an ikigai service off-box and hand it to opsctl on the box.

Usage:
  bin/deploy <app>

Arguments:
  <app>        service to deploy (ledger, crm, dashboard, ...). Its
               <app>/etc/deploy.env supplies ACCOUNT / SSH_USER / SSH_KEY / HOST.

There is no version argument. deploy builds CURRENT main (HEAD); the release
version is read from the committed file <app>/VERSION (a bare X.Y.Z) and shipped
as v<X.Y.Z>. Bump the file first with `bin/bump <app> <field>`.

Flags:
  -h, --help   show this help.
  --dry-run    do the full off-box build (produce the artifact) but PRINT the
               scp / ssh / opsctl install commands instead of running them.
               Equivalent to DRY_RUN=1.

Environment:
  DRY_RUN=1    same as --dry-run.

What it does (PLAN §1.5):
  source <app>/etc/deploy.env
  -> build CURRENT main (HEAD) in a throwaway `git worktree`
     (CGO_ENABLED=0 GOOS=linux GOARCH=amd64 GOWORK=off -trimpath -buildvcs=false,
      ldflags -X appkit.version=v<X.Y.Z> -X appkit.commit=<short-sha>[-dirty])
  -> read the version from the worktree's <app>/VERSION, ship as v<X.Y.Z>
  -> scp the single static artifact to the box /tmp
  -> ssh sudo opsctl install <app> v<X.Y.Z> --artifact /tmp/<file>

There is NO install logic locally: opsctl on the box owns release dirs, atomic
swap, migrate, restart, and rollback.
USAGE
}

# --- parse args -------------------------------------------------------------
DRY_RUN="${DRY_RUN:-0}"
APP=""
for arg in "$@"; do
  case "$arg" in
    -h|--help)  usage; exit 0 ;;
    --dry-run)  DRY_RUN=1 ;;
    -*)         echo "!! unknown flag: $arg" >&2; usage >&2; exit 2 ;;
    *)
      if [ -z "$APP" ]; then APP="$arg"
      else echo "!! too many arguments: $arg" >&2; usage >&2; exit 2
      fi
      ;;
  esac
done

[ -n "$APP" ] || { echo "!! missing <app>" >&2; usage >&2; exit 2; }

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"

[ -d "$APP" ] || { echo "!! no such service dir: ${APP}/" >&2; exit 1; }
[ -f "${APP}/etc/deploy.env" ] || { echo "!! missing ${APP}/etc/deploy.env" >&2; exit 1; }
[ -f "${APP}/VERSION" ] || { echo "!! missing ${APP}/VERSION (the committed version source of truth) — bump it with bin/bump first" >&2; exit 1; }

# --- routing/auth config (non-secret) --------------------------------------
# shellcheck source=/dev/null
. "${APP}/etc/deploy.env"
HOST="${HOST:-${ACCOUNT}.metaspot.org}"
SSH_KEY="${SSH_KEY/#\~/$HOME}"   # expand a leading ~ ; contents are never read/printed
: "${SSH_USER:?SSH_USER must be set in ${APP}/etc/deploy.env}"

# --- resolve the build commit -> current main (HEAD) -----------------------
# Git tags are NO LONGER the version mechanism. The build source is always the
# current main tip (HEAD): whatever is committed on main is what ships. The
# version itself is read below from the worktree's <app>/VERSION (the actual build
# source), not from any tag.
SHA="$(git rev-parse --short HEAD)"
COMMIT_STAMP="${SHA}"

echo ">> ${APP}: building current main (HEAD ${SHA})"

# --- throwaway worktree of HEAD --------------------------------------------
WORKTREE="$(mktemp -d "${TMPDIR:-/tmp}/ikigai-deploy-${APP}.XXXXXX")"
ARTIFACT_DIR="$(mktemp -d "${TMPDIR:-/tmp}/ikigai-artifact-${APP}.XXXXXX")"
ARTIFACT="${ARTIFACT_DIR}/${APP}"

cleanup() {
  # Remove the throwaway worktree on exit (success OR failure), then its dir.
  git worktree remove --force "$WORKTREE" >/dev/null 2>&1 || rm -rf "$WORKTREE"
  git worktree prune >/dev/null 2>&1 || true
}
trap cleanup EXIT

echo ">> git worktree add --detach ${WORKTREE} HEAD"
# mktemp created the dir; --detach onto an existing empty dir needs it gone first.
rm -rf "$WORKTREE"
# Detached checkout of HEAD — this materializes exactly what is committed on main,
# EXCLUDING any uncommitted edits in the operator's working tree. That guarantee
# (artifact == committed main) is the whole point of the file-on-main model.
git worktree add --detach "$WORKTREE" HEAD >/dev/null

# --- read the version FROM THE WORKTREE's <app>/VERSION ---------------------
# Read the bare version from the actual build source (the worktree), strip
# whitespace/newline, validate it is a bare X.Y.Z, then prepend "v" for the BARE
# release name handed to opsctl / used in the box release dir (releases/v<X.Y.Z>/)
# and stamped into the binary — matching how the binary self-reports.
VER="$(tr -d '[:space:]' < "$WORKTREE/$APP/VERSION")"
if [[ ! "$VER" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "!! ${APP}/VERSION (in the build worktree) is not a bare X.Y.Z (got: '${VER}')" >&2
  exit 1
fi
BARE="v$VER"

echo ">> ${APP}: release ${BARE} (commit ${COMMIT_STAMP})"

# The build source is the worktree — a detached checkout of HEAD. Re-derive the
# dirty flag FROM THE WORKTREE (the actual build source), so the stamp tells the
# truth about exactly what was compiled. Clean by construction for a HEAD checkout
# with no uncommitted changes in the worktree (the normal case) → empty suffix;
# the generic check still surfaces "-dirty" if a build is ever driven from a dirty
# source tree.
if [ -n "$(git -C "$WORKTREE" status --porcelain)" ]; then
  COMMIT_STAMP="${SHA}-dirty"
fi

# --- build inside the worktree's <app>/ dir --------------------------------
# Running inside <app>/ makes ./cmd/<app> and the `replace … => ../<lib>`
# directives resolve against the worktree's sibling lib trees — no network, no
# go.work (GOWORK=off). The artifact lands OUTSIDE the worktree so it survives
# the worktree removal.
LDFLAGS="-s -w -X appkit.version=${BARE} -X appkit.commit=${COMMIT_STAMP}"
echo ">> build ${APP} -> ${ARTIFACT}"
(
  cd "${WORKTREE}/${APP}"
  CGO_ENABLED=0 GOOS=linux GOARCH=amd64 GOWORK=off \
    go build -trimpath -buildvcs=false \
      -ldflags "${LDFLAGS}" \
      -o "${ARTIFACT}" "./cmd/${APP}"
)
[ -x "$ARTIFACT" ] || { echo "!! build did not produce ${ARTIFACT}" >&2; exit 1; }
echo ">> built $(basename "$ARTIFACT") ($(du -h "$ARTIFACT" | cut -f1))"

# --- hand off to opsctl on the box (or print, in dry-run) ------------------
REMOTE_ARTIFACT="/tmp/${APP}-${BARE}"
SCP_CMD=(scp -i "$SSH_KEY" "$ARTIFACT" "${SSH_USER}@${HOST}:${REMOTE_ARTIFACT}")
SSH_CMD=(ssh -i "$SSH_KEY" "${SSH_USER}@${HOST}"
  "sudo opsctl install ${APP} ${BARE} --artifact ${REMOTE_ARTIFACT}")

if [ "$DRY_RUN" = "1" ]; then
  echo ">> DRY RUN — not shipping. The box half would run:"
  echo "   ${SCP_CMD[*]}"
  echo "   ${SSH_CMD[*]}"
  echo ">> dry-run complete. Artifact: ${ARTIFACT}"
  exit 0
fi

echo ">> scp ${APP} ${BARE} -> ${HOST}:${REMOTE_ARTIFACT}"
"${SCP_CMD[@]}"

echo ">> ssh sudo opsctl install ${APP} ${BARE}"
"${SSH_CMD[@]}"

echo ">> deploy complete: ${APP} ${BARE} (${COMMIT_STAMP})"
