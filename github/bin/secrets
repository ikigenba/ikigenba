#!/usr/bin/env bash
# bin/secrets — seed/rotate github's secrets in the shared app-config blob.
#
# Workstation-side control-plane action (no ssh, no box). NON-DESTRUCTIVE
# read-modify-write of ONLY this app's key in /ikigenba/<ACCOUNT>/app-config
# (a single SecureString shared across every app on the box). Every other
# app's key in the blob is preserved untouched.
#
# github has three config values, all read via getenv at the composition root
# (D2): IKIGENBA_APP_ID, IKIGENBA_APP_PRIVATE_KEY, IKIGENBA_GITHUB_ORG. The App
# ID and org are non-secret but travel here too so the box gets the full env
# from one place; the private key is a multiline PEM. ikigenba-launch exports
# each blob key via `jq @sh` + eval, which preserves the PEM's internal
# newlines, so the key round-trips intact. They MUST be seeded BEFORE first
# start — ikigenba-launch hard-fails if .["github"] is missing from app-config.
#
# Values come from ~/.secrets/<NAME> (same source as the local .envrc); any can
# be overridden by an env var of the same name. Values are NEVER read aloud,
# printed, or logged — only masked in the summary below. Non-secret box-derived
# config (resource id, auth server, db path) is NOT stored here.
#
# Requires a live SSO session (`aws sso login --profile int`) — the user runs
# that interactively; this script does not.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env
. etc/deploy.env

PARAM="/ikigenba/${ACCOUNT}/app-config"
AWS_PROFILE_NAME="${AWS_PROFILE:-${ACCOUNT}}"
AWS_REGION_NAME="${AWS_REGION:-us-east-2}"
SECRETS_DIR="${SECRETS_DIR:-$HOME/.secrets}"

aws_() { aws --profile "$AWS_PROFILE_NAME" --region "$AWS_REGION_NAME" "$@"; }

# resolve <NAME> — single-token config (App ID, org): env override or file,
# with all whitespace stripped.
resolve() {
  local name="$1" val
  if [ -n "${!name:-}" ]; then
    val="${!name}"
  elif [ -r "$SECRETS_DIR/$name" ]; then
    val="$(cat "$SECRETS_DIR/$name")"
  else
    echo "!! $name not set and $SECRETS_DIR/$name not readable" >&2
    exit 1
  fi
  printf '%s' "$val" | tr -d '[:space:]'
}

# resolve_multiline <NAME> — the PEM private key: env override or file, with
# ONLY leading/trailing whitespace trimmed (command substitution drops trailing
# newlines) so the PEM's internal newlines survive — matching the local .envrc's
# `export IKIGENBA_APP_PRIVATE_KEY="$(cat ~/.secrets/IKIGENBA_APP_PRIVATE_KEY)"`.
resolve_multiline() {
  local name="$1" val
  if [ -n "${!name:-}" ]; then
    val="${!name}"
  elif [ -r "$SECRETS_DIR/$name" ]; then
    val="$(cat "$SECRETS_DIR/$name")"
  else
    echo "!! $name not set and $SECRETS_DIR/$name not readable" >&2
    exit 1
  fi
  printf '%s' "$val"
}

APP_ID="$(resolve IKIGENBA_APP_ID)"
GITHUB_ORG="$(resolve IKIGENBA_GITHUB_ORG)"
PRIVATE_KEY="$(resolve_multiline IKIGENBA_APP_PRIVATE_KEY)"

[ -n "$APP_ID" ]      || { echo "!! IKIGENBA_APP_ID is empty" >&2; exit 1; }
[ -n "$GITHUB_ORG" ]  || { echo "!! IKIGENBA_GITHUB_ORG is empty" >&2; exit 1; }
[ -n "$PRIVATE_KEY" ] || { echo "!! IKIGENBA_APP_PRIVATE_KEY is empty" >&2; exit 1; }
case "$PRIVATE_KEY" in
  *"-----BEGIN"*"PRIVATE KEY-----"*) : ;;
  *) echo "!! IKIGENBA_APP_PRIVATE_KEY does not look like a PEM private key" >&2; exit 1 ;;
esac

EXISTING="$(aws_ ssm get-parameter --name "$PARAM" --with-decryption \
  --query Parameter.Value --output text 2>/dev/null || true)"
if BASE="$(printf '%s' "$EXISTING" | jq -e . 2>/dev/null)"; then :; else BASE='{}'; fi

NEW="$(printf '%s' "$BASE" | jq \
  --arg n "$APP" --arg id "$APP_ID" --arg key "$PRIVATE_KEY" --arg org "$GITHUB_ORG" \
  '.[$n] = {IKIGENBA_APP_ID:$id, IKIGENBA_APP_PRIVATE_KEY:$key, IKIGENBA_GITHUB_ORG:$org}')"

mask() { local s="$1"; [ "${#s}" -le 8 ] && { echo '****'; return; }; \
         printf '%s…%s\n' "${s:0:4}" "${s: -4}"; }
SIBLINGS="$(printf '%s' "$BASE" | jq -r --arg n "$APP" \
  'keys - [$n] | join(", ") | if . == "" then "(none)" else . end')"

echo
echo "  SECRETS — write key .${APP} into ${PARAM}"
echo "    profile/region          : ${AWS_PROFILE_NAME} / ${AWS_REGION_NAME}"
echo "    IKIGENBA_APP_ID         : $(mask "$APP_ID")"
echo "    IKIGENBA_GITHUB_ORG     : ${GITHUB_ORG}"
echo "    IKIGENBA_APP_PRIVATE_KEY: PEM, $(printf '%s' "$PRIVATE_KEY" | wc -l) lines ($(printf '%s' "$PRIVATE_KEY" | wc -c) bytes)"
echo "    sibling keys preserved  : $SIBLINGS"
echo
printf '  Type "yes" to write: '
read -r ANS
[ "$ANS" = "yes" ] || { echo ">> aborted (nothing written)."; exit 1; }

TMP="$(mktemp)"; chmod 600 "$TMP"
trap 'rm -f "$TMP"' EXIT
printf '%s' "$NEW" > "$TMP"
aws_ ssm put-parameter --name "$PARAM" \
  --type SecureString --overwrite --value "file://$TMP" >/dev/null

echo ">> .${APP} written to ${PARAM}. Apply with: bin/ship (then opsctl stage/deploy) or systemctl restart ${APP}."
