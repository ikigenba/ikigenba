# Inherit the repo-root .envrc (GOFLAGS=-buildvcs=false for the worktree layout).
source_up

export ANTHROPIC_API_KEY="$(cat ~/.secrets/ANTHROPIC_API_KEY)"
export OPENAI_API_KEY="$(cat ~/.secrets/OPENAI_API_KEY)"
export GEMINI_API_KEY="$(cat ~/.secrets/GEMINI_API_KEY)"
export ZAI_API_KEY="$(cat ~/.secrets/ZAI_API_KEY)"
export OPENROUTER_API_KEY="$(cat ~/.secrets/OPENROUTER_API_KEY)"

# Non-secret local-dev config (PROMPTS_* public config) gets added here when the
# service is built — port 3002, resource id, auth server, db path, log level,
# PROMPTS_RUN_TTL — composed the same way dashboard/notify do above.
