#!/usr/bin/env bash
# Foreground dev nginx for the ikigenba suite. Ctrl-C to stop.
# Unprivileged: all state (pid, logs, temp) stays under this directory.
set -euo pipefail
here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo="$(cd "$here/.." && pwd)"

# Regenerate the dev /srv/<svc>/ location fragments from each service's
# etc/nginx.conf. The fragments carry their loopback port as a literal (fixed by
# the registry), so this just copies them verbatim — the dev mirror of each
# service's opsctl setup. Generated files are gitignored and overwritten every
# run, so this stays idempotent.
mkdir -p "$here/locations"
# nginx.conf puts all scratch paths (client_body/proxy/fastcgi/uwsgi/scgi) under
# tmp/; nginx won't create the parent itself, so ensure it exists.
mkdir -p "$here/tmp"
for svc in crm cron dropbox gmail ledger notify prompts scripts sites webhooks wiki; do
	frag="$repo/$svc/etc/nginx.conf"
	[ -f "$frag" ] || continue
	cp "$frag" "$here/locations/${svc}.conf"
done

exec /usr/sbin/nginx -p "$here" -c "$here/nginx.conf" -g 'daemon off;'
