#!/usr/bin/env bash
# bin/build — produce the deploy artifacts for the dropbox service.
#
# Outputs in $REPO/build/:
#   build/dropbox      — shell wrapper that becomes /opt/dropbox/bin/run
#                    (metaspot-launch exec()s this). Composes the public-origin
#                    DROPBOX_RESOURCE_ID / DROPBOX_AUTH_SERVER from METASPOT_DOMAIN and
#                    execs the real binary with its listen flags.
#   build/dropbox.bin  — the Go binary (linux/amd64, static, stripped),
#                    shipped to /opt/dropbox/bin/dropbox.bin.
#
# metaspot-launch exec()s /opt/<app>/bin/run with no args (it has already sourced
# /etc/metaspot/env and manifest.env AND the SSM app-config secrets, so
# METASPOT_DOMAIN, PORT, and dropbox's three Dropbox secrets are already in the
# env). The wrapper sets only NON-SECRET public config (resource id, auth server,
# db/mirror/generation paths, app-folder root, longpoll timeout, max-entry-retries)
# and execs the binary; it NEVER touches DROPBOX_APP_KEY / DROPBOX_APP_SECRET /
# DROPBOX_REFRESH_TOKEN, which arrive from app-config (via metaspot-launch) and are
# read by the binary via getenv at its composition root. The shared event-plane
# knobs (OUTBOX_RETENTION_*) keep their OUTBOX_ prefix and default in the binary.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env

VERSION="${VERSION:-$(git describe --tags --always --dirty 2>/dev/null || echo dev)}"

mkdir -p build

# -buildvcs=false: this module is a subdirectory of the ikigai mono-repo, whose
# .git lives at the (bare) repo root. Go's automatic VCS stamping walks up to
# that root and runs git there, which fails (exit 128) and aborts the build. The
# version is injected explicitly via -ldflags below, so the VCS stamp is redundant.
CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
  go build -trimpath -buildvcs=false -ldflags "-s -w -X main.version=${VERSION}" \
    -o "build/${APP}.bin" ./cmd/dropbox

cat > "build/${APP}" <<'WRAPPER'
#!/usr/bin/env bash
set -euo pipefail
: "${METASPOT_DOMAIN:?metaspot-launch must have sourced /etc/metaspot/env}"
: "${PORT:?PORT must be set (etc/manifest.env)}"
# dropbox is a path-routed service mounted at /srv/dropbox/ behind nginx. Its canonical
# resource id is the public mount URL, and the AS it points clients at is the
# apex front door — both built from the bare account domain.
export DROPBOX_RESOURCE_ID="https://${METASPOT_DOMAIN}/srv/dropbox/mcp"
export DROPBOX_AUTH_SERVER="https://${METASPOT_DOMAIN}"
# State paths under /opt/dropbox/data (created by bin/setup, owned by the app
# user; bin/deploy never touches them). The mirror is a private subdir of data.
export DROPBOX_DB_PATH=/opt/dropbox/data/dropbox.db
export DROPBOX_MIRROR_PATH=/opt/dropbox/data/mirror
# Generation/epoch sidecar lives OUTSIDE the DB file so a file-level restore does
# not roll it back (event-protocol.md §9.3).
export DROPBOX_GENERATION_PATH=/opt/dropbox/data/dropbox.db.generation
# Non-secret sync knobs (PLAN.md §9). Empty app-folder root = the app folder root.
export DROPBOX_APP_FOLDER_ROOT=""
export DROPBOX_LONGPOLL_TIMEOUT=480
export DROPBOX_MAX_ENTRY_RETRIES=5
exec /opt/dropbox/bin/dropbox.bin \
  --ip 127.0.0.1 \
  --port "${PORT}"
WRAPPER
chmod 0755 "build/${APP}"

# Bundle the shared, repo-root resolver so the on-box wrapper (/opt/${APP}/bin/run)
# can resolve peer service addresses by name from their deploy manifests. bin/registry
# is the single source of truth; every service ships a byte-identical copy.
cp "$REPO/../bin/registry" "build/registry"
chmod 0755 "build/registry"

echo "build/${APP}"
echo "build/${APP}.bin"
echo "build/registry"
