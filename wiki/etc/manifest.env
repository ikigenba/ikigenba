APP=wiki
MOUNT=/srv/wiki/
DEFAULT=false
PORT=3006
# MCP=true marks this service for inclusion in the dashboard service inventory
MCP=true
# Comma-separated upstream producer names whose feeds this service consumes. wiki
# is a notify-shaped eventplane consumer of dropbox's file-lifecycle events for
# the hardcoded wiki/ingest folder (Task 6.1): a file landing in that folder is
# filed autonomously through the same async ingest core as wiki_ingest_text.
CONSUMES=dropbox
# Ingest agent config (non-secret; PLAN Decision 3). The ANTHROPIC_API_KEY secret
# is NOT here — it flows via SSM app-config / .envrc. Model + per-job cost ceiling
# are config, not hardcoded in the agent; the bin/build wrapper exports these.
WIKI_INGEST_MODEL=claude-sonnet-4-6
WIKI_INGEST_MAX_TOKENS=8192
