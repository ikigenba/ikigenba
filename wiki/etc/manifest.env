APP=wiki
MOUNT=/srv/wiki/
DEFAULT=false
PORT=3006
# MCP=true marks this service for inclusion in the dashboard service inventory
MCP=true
# Ingest agent config (non-secret; PLAN Decision 3). The ANTHROPIC_API_KEY secret
# is NOT here — it flows via SSM app-config / .envrc. Model + per-job cost ceiling
# are config, not hardcoded in the agent; the bin/build wrapper exports these.
WIKI_INGEST_MODEL=claude-sonnet-4-6
WIKI_INGEST_MAX_TOKENS=8192
