#!/usr/bin/env python3
"""Deterministic scorer for production question analysis."""

import json
import math
import os
import re
import subprocess
import sys

THRESHOLD = 0.80
MARGIN = 0.03
W_SUB_QUERIES, W_KEYWORDS, W_ALIASES = 0.50, 0.30, 0.20


def embed(texts):
    if not texts:
        return []
    proc = subprocess.run(
        [os.environ.get("EMBED_BIN", "embed")],
        input=json.dumps(texts),
        capture_output=True,
        text=True,
    )
    if proc.returncode != 0:
        raise RuntimeError(f"embed CLI failed (exit {proc.returncode}): {proc.stderr.strip()}")
    vectors = json.loads(proc.stdout)["embeddings"]
    if len(vectors) != len(texts):
        raise RuntimeError(f"embed returned {len(vectors)} vectors for {len(texts)} texts")
    return vectors


def cosine(a, b):
    if not a or len(a) != len(b):
        raise ValueError("embedding vector dimensions differ or are empty")
    dot = sum(x * y for x, y in zip(a, b))
    aa = sum(x * x for x in a)
    bb = sum(y * y for y in b)
    return dot / math.sqrt(aa * bb) if aa and bb else 0.0


def digits_compatible(a, b):
    a_digits = re.findall(r"[0-9]+", a)
    b_digits = re.findall(r"[0-9]+", b)
    return not a_digits or not b_digits or bool(set(a_digits) & set(b_digits))


def align(gold, got):
    if not gold or not got:
        return 0
    vectors = embed(list(gold) + list(got))
    sims = [
        [cosine(vectors[gi], vectors[len(gold) + ei]) for ei in range(len(got))]
        for gi in range(len(gold))
    ]
    candidates = sorted(
        ((gi, ei) for gi in range(len(gold)) for ei in range(len(got))),
        key=lambda pair: (-sims[pair[0]][pair[1]], pair[0], pair[1]),
    )
    gold_used = set()
    got_used = set()
    for gi, ei in candidates:
        similarity = sims[gi][ei]
        if gi in gold_used or ei in got_used or similarity < THRESHOLD:
            continue
        gold_alternative = max(
            (sims[gi][other] for other in range(len(got)) if other != ei),
            default=-math.inf,
        )
        got_alternative = max(
            (sims[other][ei] for other in range(len(gold)) if other != gi),
            default=-math.inf,
        )
        if similarity - gold_alternative < MARGIN or similarity - got_alternative < MARGIN:
            continue
        if not digits_compatible(gold[gi], got[ei]):
            continue
        gold_used.add(gi)
        got_used.add(ei)
    return len(gold_used)


def metrics(matched, missed, spurious):
    if matched == missed == spurious == 0:
        precision = recall = f1 = 1.0
    else:
        precision = matched / (matched + spurious) if matched + spurious else 0.0
        recall = matched / (matched + missed) if matched + missed else 0.0
        f1 = 2 * precision * recall / (precision + recall) if precision + recall else 0.0
    return {
        "matched": matched,
        "missed": missed,
        "spurious": spurious,
        "precision": precision,
        "recall": recall,
        "f1": f1,
    }


def parse_candidate(text):
    body = text.strip()
    fence = re.search(r"```(?:json)?\s*\n(.*?)```", body, re.DOTALL)
    if fence:
        body = fence.group(1).strip()
    if not body.startswith("{"):
        start, end = body.find("{"), body.rfind("}")
        if start < 0 or end <= start:
            raise ValueError("output contains no JSON object")
        body = body[start : end + 1]
    value = json.loads(body)
    if not isinstance(value, dict):
        raise ValueError("output is not a JSON object")
    for key in ("sub_queries", "keywords", "aliases"):
        if not isinstance(value.get(key), list) or not all(isinstance(item, str) for item in value[key]):
            raise ValueError(f'output JSON has no valid "{key}" string array')
    return value


def main():
    if len(sys.argv) != 2:
        print("usage: score <case-dir>", file=sys.stderr)
        return 2
    with open(os.path.join(sys.argv[1], "gold.json"), encoding="utf-8") as source:
        gold = json.load(source)["gold"]
    try:
        got = parse_candidate(sys.stdin.read())
    except (ValueError, json.JSONDecodeError) as exc:
        print(json.dumps({"score": 0.0, "feedback": f"unscorable output: {exc}"}))
        return 0

    details = {}
    for key in ("sub_queries", "keywords", "aliases"):
        matched = align(gold[key], got[key])
        details[key] = metrics(matched, len(gold[key]) - matched, len(got[key]) - matched)
    composite = (
        W_SUB_QUERIES * details["sub_queries"]["f1"]
        + W_KEYWORDS * details["keywords"]["f1"]
        + W_ALIASES * details["aliases"]["f1"]
    )
    feedback = ", ".join(f"{key} F1 {details[key]['f1']:.3f}" for key in details)
    print(json.dumps({"score": round(composite, 6), "feedback": feedback, "details": details}))
    return 0


if __name__ == "__main__":
    sys.exit(main())
