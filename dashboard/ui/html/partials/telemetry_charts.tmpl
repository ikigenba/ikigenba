{{define "telemetry_charts"}}
<div class="telemetry-charts" aria-label="Telemetry charts">
  <div class="telemetry-chart-slot">{{.SystemMemory}}</div>
  <div class="telemetry-chart-slot">{{.SystemDisk}}</div>
  <div class="telemetry-chart-slot">{{.ServiceMemory}}</div>
  <div class="telemetry-chart-slot">{{.ServiceDisk}}</div>
</div>
{{end}}
