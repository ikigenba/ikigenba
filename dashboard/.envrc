# Inherit the repo-root .envrc (GOFLAGS=-buildvcs=false for the worktree layout).
source_up

export GOOGLE_CLIENT_ID="$(cat ~/.secrets/GOOGLE_CLIENT_ID)"
export GOOGLE_CLIENT_SECRET="$(cat ~/.secrets/GOOGLE_CLIENT_SECRET)"
export GOOGLE_WORKSPACE_DOMAIN="$(cat ~/.secrets/GOOGLE_WORKSPACE_DOMAIN)"

# GitHub sign-in (D25): the ikigenba GitHub App's OAuth pair + the admitted org.
# The ~/.secrets names are symlinks to IKIGENBA_APP_CLIENT_ID /
# IKIGENBA_APP_CLIENT_SECRET / IKIGENBA_GITHUB_ORG; the strict line form below
# is what bin/push-secrets parses to build the SSM app-config parameter.
export GITHUB_CLIENT_ID="$(cat ~/.secrets/GITHUB_CLIENT_ID)"
export GITHUB_CLIENT_SECRET="$(cat ~/.secrets/GITHUB_CLIENT_SECRET)"
export GITHUB_ORG="$(cat ~/.secrets/GITHUB_ORG)"

# The public front door (nginx). Every OAuth hop the client sees — AS metadata
# issuer/endpoints and the dashboard→Google callback — is built from this, so it
# must be the nginx origin, never the dashboard's loopback :3000 (unreachable in
# prod and a bypass of the nginx-only access model).
export DASHBOARD_PUBLIC_BASE_URL="http://localhost:8080"
# Production: https://int.ikigenba.com

# The AS resource list is DERIVED at startup from the per-service manifests under
# this root (the mono-repo root, parent of dashboard/), one /srv/<svc>/mcp
# identifier per MCP service, built from DASHBOARD_PUBLIC_BASE_URL's origin
# (http://localhost:8080) — same origin nginx fronts on :8080 in dev. Adding a
# service is a restart, not an env edit. Production: DASHBOARD_MANIFEST_ROOT=/opt.
export DASHBOARD_MANIFEST_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/.." && pwd)"
