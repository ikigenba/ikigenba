# Inherit the repo-root .envrc (GOFLAGS=-buildvcs=false for the worktree layout).
source_up

export NTFY_TOPIC="$(cat ~/.secrets/NTFY_TOPIC)"
export NTFY_API_KEY="$(cat ~/.secrets/NTFY_API_KEY)"

# Non-secret local-dev config (overrides the in-binary defaults).
export NOTIFY_NTFY_BASE_URL="https://ntfy.sh"
